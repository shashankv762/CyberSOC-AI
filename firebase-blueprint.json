{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the CyberSOC platform",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's full name"
        },
        "photoURL": {
          "type": "string",
          "description": "URL to user's profile photo"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "analyst"],
          "description": "User's role in the system"
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the user's last login"
        }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and roles"
    }
  }
}
